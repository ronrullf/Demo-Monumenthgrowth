---
import Icon from "./Icon.astro";
import { whatsappHref } from "../lib/whatsapp";

interface Props {
  label: string;
  text?: string;
  class?: string;
}

const { label, text, class: className = "" } = Astro.props;
---

<a
  href={whatsappHref(text)}
  target="_blank"
  rel="noopener"
  class={`cta-shine inline-flex items-center justify-center gap-2 rounded-lg bg-(--color-wa) px-6 py-3.5 font-sans font-medium text-white transition-[background-color,transform] duration-150 hover:bg-(--color-wa-ink) active:scale-[0.98] ${className}`}
>
  <Icon name="whatsapp" class="h-5 w-5 shrink-0" />
  <span>{label}</span>
</a>
