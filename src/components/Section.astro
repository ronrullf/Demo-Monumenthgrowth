---
interface Props {
  ariaLabel: string;
  class?: string;
  id?: string;
}

const { ariaLabel, class: className = "", id } = Astro.props;
---

<section aria-label={ariaLabel} id={id} class={`reveal mx-auto max-w-5xl px-5 py-20 md:py-28 ${className}`}>
  <slot />
</section>

<script>
  const observed = new WeakSet<Element>();

  function observe() {
    const targets = document.querySelectorAll<HTMLElement>(".reveal, .reveal-item");
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
    );

    targets.forEach((el) => {
      if (!observed.has(el)) {
        observed.add(el);
        io.observe(el);
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", observe);
  } else {
    observe();
  }
</script>
